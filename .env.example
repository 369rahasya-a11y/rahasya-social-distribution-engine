# =============================================================
# RAHASYA SOCIAL DISTRIBUTION ENGINE — ENVIRONMENT VARIABLES
# =============================================================

# --- SUPABASE ---
# Your Supabase project URL (found in: Project Settings > API > Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — KEEP SECRET. Never commit. Never expose client-side.
# Found in: Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- FACEBOOK ---
# Your Facebook Page ID (found in Page Settings or Meta Business Suite)
FACEBOOK_PAGE_ID=123456789012345

# Long-lived Facebook Page Access Token (60 days or permanent via System User)
# Generate at: developers.facebook.com > Graph API Explorer
# Required permissions: pages_manage_posts, pages_read_engagement
FACEBOOK_ACCESS_TOKEN=EAABs...

# --- INSTAGRAM ---
# Your Instagram Business Account ID
# Found in Meta Business Suite > Business Settings > Instagram Accounts
# Or via Graph API: GET /me?fields=instagram_business_account
INSTAGRAM_BUSINESS_ID=987654321098765

# Instagram uses the same Facebook access token above (linked account)
# Make sure the access token has: instagram_basic, instagram_content_publish

# --- THREADS ---
# Your Threads User ID
# Retrieved via Threads API: GET /me?fields=id,username
THREADS_USER_ID=111222333444555

# Threads long-lived access token
# Generate via Threads API auth flow
# Required scopes: threads_basic, threads_content_publish
THREADS_ACCESS_TOKEN=THBwfT...

# --- OPTIONAL ---
# Node environment (development | production)
NODE_ENV=production

# Log level (debug | info | warn | error)
LOG_LEVEL=info
